# ARGUS Copilot — environment matrix (copy to .env for local overrides; never commit .env)
# Code is identical across environments; only these values change (12-factor).

# --- engines -----------------------------------------------------------------
ARGUS_FAST=1                  # 1 = dev (small startup ensemble/bands) | 0 = full fidelity (cluster)
ARGUS_SEED=42                 # global simulation seed; embedded in every manifest
#ARGUS_THETA_CACHE=output/theta_deployed.json

# --- persistence ---------------------------------------------------------------
ARGUS_DB=/tmp/argus/copilot.db                 # sqlite path (ignored when DATABASE_URL set)
#DATABASE_URL=postgresql://argus:argus-dev-only@localhost:5432/argus   # -> PostgreSQL backend

# --- event bus (optional; FileBus JSONL spool used when unset) ---
#ARGUS_KAFKA_BROKERS=kafka:9092   # switches bus to aiokafka producers/consumers

# --- ingestion credentials (optional; workers refuse live mode without them) ---
#ACLED_KEY=your-api-key
#ACLED_EMAIL=you@example.org

# --- NLU assist (optional; intent/slot parsing only — numbers always from engines) ---
# Preferred: OpenAI-compatible vLLM (Task 76). Pin the model; revision pinned in deploy.
#ARGUS_LLM_URL=http://localhost:8001/v1
#ARGUS_LLM_MODEL=Qwen2.5-1.5B-Instruct
#ARGUS_LLM_MAX_TOKENS=64
# Alternative backend:
#OLLAMA_URL=http://localhost:11434
#OLLAMA_MODEL=llama3.1

# --- gateway / auth (Task 74; OIDC/JWT + clearance claims) ---
ARGUS_AUTH_ENABLED=0          # 1 = require bearer JWT on guarded endpoints (prod); 0 = trusted-local dev
#ARGUS_JWT_SECRET=change-me   # HS256 signing secret (dev / service-to-service)
#ARGUS_JWT_ALGORITHMS=HS256   # comma-separated; use RS256 with OIDC_JWKS_URL for SSO
#OIDC_ISSUER=https://idp.internal/realms/argus      # expected `iss`
#OIDC_AUDIENCE=argus-copilot                         # expected `aud`
#OIDC_JWKS_URL=https://idp.internal/realms/argus/protocol/openid-connect/certs  # RS256 keys
#ARGUS_CLEARANCE_CLAIM=clearance                     # JWT claim carrying OPEN|CONFIDENTIAL|SECRET|TOPSECRET
#ARGUS_AUTH_DEV_CLEARANCE=SECRET                     # principal clearance when auth disabled

# --- service ----------------------------------------------------------------------
ARGUS_CORS_ORIGINS=*          # comma-separated origins in production, e.g. https://argus.internal

# Environment profiles:
#   dev      ARGUS_FAST=1, sqlite, no Ollama
#   CI       ARGUS_FAST=1, sqlite job + DATABASE_URL job (postgres:16 service)
#   compose  ARGUS_FAST=1, ARGUS_DB=/data/copilot.db (volume)
#   cluster  ARGUS_FAST=0, DATABASE_URL from secret, ARGUS_CORS_ORIGINS pinned
